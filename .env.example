# Orbis-Search Configuration

# AI Provider API Keys (Optional - only needed for semantic search)
# GEMINI_API_KEY=your_gemini_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here

# Embedding Provider: "local" (default), "gemini", "openai", "keyword", "auto"
# ORBIS_EMBEDDING_PROVIDER=local

# Logging Level: INFO, DEBUG, WARNING, ERROR
# ORBIS_LOG_LEVEL=INFO
